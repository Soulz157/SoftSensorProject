{
  "name": "softsensor",
  "private": true,
  "scripts": {
    "build": "dotenv run -- turbo build ",
    "dev": "dotenv run -- turbo dev",
    "dev:client": "dotenv run -- pnpm --filter=client dev",
    "dev:server": "dotenv run -- pnpm --filter=backend dev",
    "start": "dotenvx run -- turbo start",
    "test": "dotenvx run -- turbo test",
    "test:coverage": "dotenvx run -- turbo test:cov",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rimraf node_modules apps/*/node_modules .turbo",
    "db:push": "dotenvx run -- pnpm --filter=@softsensor/prisma push",
    "db:seed": "dotenvx run -- pnpm --filter=@softsensor/prisma seed",
    "db:studio": "dotenvx run -- pnpm --filter=@softsensor/prisma studio",
    "db:generate": "dotenvx run -- pnpm --filter=@softsensor/prisma generate",
    "db:migrate:dev": "dotenvx run -- pnpm --filter=@softsensor/prisma migrate:dev",
    "db:migrate:draft": "dotenvx run -- pnpm --filter=@softsensor/prisma migrate:draft",
    "db:migrate:deploy": "dotenvx run -- pnpm --filter=@softsensor/prisma migrate:deploy",
    "db:migrate:reset": "dotenvx run -- pnpm --filter=@softsensor/prisma migrate:reset"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.65.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "rimraf": "^6.1.3",
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/client"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AuthAction {
  LOGIN
  LOGOUT
}

enum WorkspaceAction {
  CREATED
  UPDATED
  DELETED
  MODEL_ADDED
  MODEL_REMOVED
  MODEL_UPDATED
  NODE_ADDED
  NODE_REMOVED
  NODE_UPDATED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  TRIALING
}

enum WorkspaceRole {
  OWNER
  STAFF
  VIEWER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  firstName     String?
  lastName      String?
  password      String?
  company       String?
  role          Role           @default(USER)
  blockedAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  workspaces    Workspace[]
  refreshTokens RefreshToken[]
  authLogs      AuthLog[]
  workspaceLogs WorkspaceLog[]

  subscriptions       Subscription[]
  passwordResetTokens PasswordResetToken[]
  workspaceMembers    WorkspaceMember[]
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Workspace {
  id          String            @id @default(uuid())
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id])
  name        String
  icon        String
  color       String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  logs        WorkspaceLog[]
  members     WorkspaceMember[]
  nodes       Nodes[]
  models      Model[]
  edges       Edge[]

  @@index([ownerId])
}

model Nodes {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  data        Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  models      Model[]

  @@index([workspaceId])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Model {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  data        Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  nodes       Nodes?    @relation(fields: [nodesId], references: [id])
  nodesId     String?

  @@index([workspaceId])
}

model Plan {
  id             String @id @default(uuid())
  name           String @unique
  maxWorkspaces  Int    @default(1)
  price          Float?
  durationMonths Int    @default(1)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime

  paymentId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model AuthLog {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AuthAction
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model WorkspaceLog {
  id          String          @id @default(uuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  action      WorkspaceAction
  details     Json?
  createdAt   DateTime        @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Edge {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId     String
  targetId     String
  sourceHandle String?
  targetHandle String?
  createdAt    DateTime  @default(now())

  @@unique([workspaceId, sourceId, targetId, sourceHandle, targetHandle])
  @@index([workspaceId])
}
